{
    "fullScreen": {
        "enable": false
    },
    "fpsLimit": 60,
    "detectRetina": true,
    "pauseOnBlur": true,
    "pauseOnOutsideViewport": false,
    "particles": {
        "number": {
            "value": 80,
            "density": {
                "enable": true,
                "width": 1920,
                "height": 1080
            }
        },
        "shape": {
            "type": "circle"
        },
        "paint": {
            "color": {
                "value": "#440505"
            },
            "fill": {
                "enable": true,
                "opacity": 0.5
            },
            "stroke": {
                "width": 1,
                "opacity": 0.5,
                "color": {
                    "value": "#440505"
                }
            }
        },
        "size": {
            "value": {
                "min": 1,
                "max": 5
            }
        },
        "links": {
            "enable": true,
            "distance": 150,
            "color": "#440505",
            "opacity": 0.4,
            "width": 2
        },
        "move": {
            "enable": true,
            "speed": 3,
            "direction": "none",
            "random": false,
            "straight": false,
            "outModes": {
                "default": "out"
            }
        }
    },
    "interactivity": {
        "detectsOn": "window",
        "events": {
            "onHover": {
                "enable": true,
                "mode": "repulse"
            },
            "onClick": {
                "enable": true,
                "mode": "push"
            }
        },
        "modes": {
            "repulse": {
                "distance": 200
            },
            "push": {
                "quantity": 4
            }
        }
    }
}
